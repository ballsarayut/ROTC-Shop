rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow authenticated users to read and write
      allow read, write: if request.auth != null;
    }
    
    // Specifically for products (public read, auth write)
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Specifically for slips (public write for checkout)
    match /slips/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // Specifically for settings/QR (public read, auth write)
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
